# Copy this file to .env and fill in values from your Firebase project settings.
# Vite embeds these at build time, so rebuild Docker after any changes.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: explicit Realtime Database URL
# If omitted, the app defaults to https://<VITE_FIREBASE_PROJECT_ID>.firebaseio.com
VITE_FIREBASE_DATABASE_URL=
